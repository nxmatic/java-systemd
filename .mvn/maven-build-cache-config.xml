<cache xmlns="http://maven.apache.org/BUILD-CACHE-CONFIG/1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://maven.apache.org/BUILD-CACHE-CONFIG/1.0.0 https://maven.apache.org/xsd/build-cache-config-1.0.0.xsd">

    <!--
        Template Maven build cache configuration
     -->

    <configuration>
        <enabled>true</enabled>
        <hashAlgorithm>SHA-256</hashAlgorithm>
        <validateXml>true</validateXml>
        <remote enabled="false">
            <url>http://host:port</url>
        </remote>
        <local>
            <maxBuildsCached>2</maxBuildsCached>
        </local>
        <projectVersioning adjustMetaInf="true"/>
    </configuration>

    <input>
        <global>
            <!-- If not defined, default glob is "*" -->
            <glob>
                {*.java,*.groovy,*.yaml,*.svcd,*.proto,*assembly.xml,assembly*.xml,*logback.xml,*.vm,*.ini,*.jks,*.properties,*.sh,*.bat}
            </glob>
            <includes>
                <!-- By default, project sources and resources directories are included (src/main/java and src/main/resources) -->
                <!-- In this example, the goal is to include a wider range of src directories (like src/main/assembly or src/main/groovy) -->
                <include>src/</include>
            </includes>
            <excludes>
                <!-- We don't want a static "hash" pom resolution (it would conflict the will to adjust the version in the manifest), -->
                <!-- we exclude this specific file (as it is already by default since it is not in an include folder -->
                <!-- The need to rebuild a project based on the pom is already computed with some intelligence by the extension. -->
                <exclude>pom.xml</exclude>
                <!-- Exclude specific files or directories -->
            </excludes>
        </global>
        <plugins>
            <!-- Exclude Jandex plugin fileSets identity noise (object hash varies each run) -->
            <plugin artifactId="jandex-maven-plugin">
                <effectivePom>
                    <excludeProperties>
                        <excludeProperty>fileSets</excludeProperty>
                        <excludeProperty>FileSet</excludeProperty>
                    </excludeProperties>
                </effectivePom>
            </plugin>
            <!-- Exclude Cobertura system property from effective POM hashing (volatile path). -->
            <plugin artifactId="maven-surefire-plugin">
                <effectivePom>
                    <excludeProperties>
                        <excludeProperty>net.sourceforge.cobertura.datafile</excludeProperty>
                        <!-- Generated per-build timestamped directory; exclude to avoid cache churn -->
                        <excludeProperty>nuxeo.runtime.home</excludeProperty>
                        <!-- Developer convenience toggles that shouldn't invalidate cached test compilation -->
                        <excludeProperty>skipTests</excludeProperty>
                        <excludeProperty>skip.surefire.tests</excludeProperty>
                        <excludeProperty>argLine</excludeProperty>
                        <!-- Debug/system properties influencing only runtime debugging; exclude to keep cache stable -->
                        <excludeProperty>hxpr.debug.dropins.argLine</excludeProperty>
                        <excludeProperty>hxpr.debug.dropins.logger</excludeProperty>
                        <excludeProperty>hxpr.debug.dropins.loglevel</excludeProperty>
                        <excludeProperty>hxpr.debug.dropins.port</excludeProperty>
                        <excludeProperty>hxpr.debug.dropins.suspend</excludeProperty>
                        <!-- Suite selector switches which tests execute, not compiled artifacts -->
                        <excludeProperty>hxpr.test-suite</excludeProperty>
                    </excludeProperties>
                </effectivePom>
            </plugin>
            <!-- Exclude jar plugin archive identity objects (object IDs vary each build) -->
            <plugin artifactId="maven-jar-plugin">
                <effectivePom>
                    <excludeProperties>
                        <excludeProperty>archive</excludeProperty>
                    </excludeProperties>
                </effectivePom>
            </plugin>
            <!-- Exclude antrun fileset definitions (directory contents varies; we only care when sources/resources change). -->
            <plugin artifactId="maven-antrun-plugin">
                <effectivePom>
                    <excludeProperties>
                        <!-- Ant run inline XML becomes serialized as a property; ignore directory listing volatility -->
                        <excludeProperty>fileset</excludeProperty>
                        <excludeProperty>fileSet</excludeProperty>
                        <excludeProperty>fileSets</excludeProperty>
                        <excludeProperty>filesets</excludeProperty>
                        <!-- Exclude jandex plugin FileSet identity noise if serialized similarly -->
                        <excludeProperty>FileSet</excludeProperty>
                    </excludeProperties>
                </effectivePom>
            </plugin>
            <!-- Exclude Failsafe test execution toggles (do not affect compiled artifacts) -->
            <plugin artifactId="maven-failsafe-plugin">
                <effectivePom>
                    <excludeProperties>
                        <excludeProperty>argLine</excludeProperty>
                        <excludeProperty>skipTests</excludeProperty>
                        <excludeProperty>skipITs</excludeProperty>
                        <excludeProperty>failIfNoSpecifiedTests</excludeProperty>
                        <!-- Mirror surefire debug exclusions -->
                        <excludeProperty>hxpr.debug.dropins.argLine</excludeProperty>
                        <excludeProperty>hxpr.debug.dropins.logger</excludeProperty>
                        <excludeProperty>hxpr.debug.dropins.loglevel</excludeProperty>
                        <excludeProperty>hxpr.debug.dropins.port</excludeProperty>
                        <excludeProperty>hxpr.debug.dropins.suspend</excludeProperty>
                        <excludeProperty>hxpr.test-suite</excludeProperty>
                    </excludeProperties>
                </effectivePom>
            </plugin>
            <!-- Exclude Spring Boot run-time only properties (do not affect compiled classes) -->
            <plugin artifactId="spring-boot-maven-plugin">
                <effectivePom>
                    <excludeProperties>
                        <excludeProperty>spring-boot.run.profiles</excludeProperty>
                        <excludeProperty>spring-boot.run.jvmArguments</excludeProperty>
                        <excludeProperty>spring-boot.run.arguments</excludeProperty>
                        <excludeProperty>jvmArguments</excludeProperty>
                    </excludeProperties>
                </effectivePom>
            </plugin>
          <!-- NOTE on Jandex (jandex.idx): The build cache <input><global> covers only source & resource roots (e.g., src/**).
              The generated Jandex index resides under target/classes/META-INF/jandex.idx and is therefore NOT part of the
              default input hash set. Excluding it explicitly isn't necessary and fine-grained per-file exclusion inside
              classesDirectory is not supported by the schema (exclude only accepts tagName). If jandex.idx changes are
              driving cache misses, the root cause is usually upstream classfile changes (timestamps, manifest resources).
              Focus on reproducible builds / deterministic class generation rather than trying to exclude the index file. -->
        </plugins>
    </input>
    <executionControl>
        <runAlways>
            <plugins>
                <plugin artifactId="maven-failsafe-plugin"/>
                <!-- Force unit tests to execute even when inputs unchanged -->
                <plugin artifactId="maven-surefire-plugin"/>
                <!-- Resolves ${org.mockito:mockito-core:jar} for surefire's argLine; setting properties is a side-effect not captured by the cache -->
                <plugin artifactId="maven-dependency-plugin"/>
            </plugins>
            <goalsLists>
                <goalsList artifactId="maven-surefire-plugin">
                    <goals>
                        <goal>test</goal>
                    </goals>
                </goalsList>
                <goalsList artifactId="maven-install-plugin">
                    <goals>
                        <goal>install</goal>
                    </goals>
                </goalsList>
                <goalsList artifactId="maven-deploy-plugin">
                    <goals>
                        <goal>deploy</goal>
                    </goals>
                </goalsList>
            </goalsLists>
        </runAlways>
        <reconcile logAllProperties="true">
            <plugins>
                <plugin artifactId="maven-compiler-plugin" goal="compile">
                    <reconciles>
                        <reconcile propertyName="source"/>
                        <reconcile propertyName="target"/>
                        <reconcile propertyName="debug"/>
                        <reconcile propertyName="debuglevel"/>
                    </reconciles>
                    <!-- whitelist of logged properties-->
                    <logs>
                        <log propertyName="includes"/>
                        <log propertyName="excludes"/>
                        <log propertyName="argLine"/>
                    </logs>
                </plugin>
                <plugin artifactId="maven-enforcer-plugin" goal="enforce">
                    <reconciles>
                        <reconcile propertyName="skip" skipValue="true"/>
                    </reconciles>
                    <!-- blacklisted from logging properties-->
                    <nologs>
                        <nolog propertyName="commandLineRules"/>
                    </nologs>
                </plugin>
            </plugins>
        </reconcile>
    </executionControl>
</cache>
